<Window x:Class="CurrencyExchangeOffice.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Currency Exchange Office" Height="650" Width="900"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#7C3AED"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Login Panel -->
        <StackPanel x:Name="LoginPanel" Width="320" HorizontalAlignment="Center"
                    VerticalAlignment="Center" Visibility="Visible">
            <TextBlock Text="💱 Currency Exchange" FontSize="24" FontWeight="Bold"
                       Foreground="#CBA6F7" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Username"/>
            <TextBox x:Name="TxtUsername" Margin="0,4,0,10"/>
            <TextBlock Text="Password"/>
            <PasswordBox x:Name="TxtPassword" Margin="0,4,0,10"/>
            <TextBlock Text="Email (register only)"/>
            <TextBox x:Name="TxtEmail" Margin="0,4,0,16"/>
            <Button Content="Login" Click="BtnLogin_Click" Margin="0,0,0,8"/>
            <Button Content="Register" Click="BtnRegister_Click" Background="#059669"/>
            <TextBlock x:Name="TxtLoginMsg" Foreground="#F38BA8" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Main App Panel -->
        <Grid x:Name="AppPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <StackPanel Background="#181825">
                <TextBlock Text="💱 Exchange" FontSize="18" FontWeight="Bold"
                           Foreground="#CBA6F7" Margin="0,0,0,20"/>
                <Button Content="📊 Rates" Click="ShowRates" Margin="0,4"/>
                <Button Content="👤 My Account" Click="ShowAccount" Margin="0,4"/>
                <Button Content="💰 Buy Currency" Click="ShowBuy" Margin="0,4"/>
                <Button Content="💵 Sell Currency" Click="ShowSell" Margin="0,4"/>
                <Button Content="📜 History" Click="ShowHistory" Margin="0,4"/>
                <Button Content="Logout" Click="Logout" Background="#F38BA8" Margin="0,40,0,0"/>
                <TextBlock x:Name="TxtUser" Margin="0,16,0,0" FontSize="11" Foreground="#6C7086"/>
            </StackPanel>

            <!-- Content Area -->
            <Grid Grid.Column="1" Margin="20">
                <!-- Rates Panel -->
                <StackPanel x:Name="PanelRates" Visibility="Visible">
                    <TextBlock Text="Current Exchange Rates" FontSize="20" FontWeight="Bold"
                               Foreground="#CBA6F7" Margin="0,0,0,16"/>
                    <Button Content="🔄 Refresh" Click="RefreshRates"
                            HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <DataGrid x:Name="GridRates" AutoGenerateColumns="False"
                              Background="#2D2D3F" Foreground="White" BorderThickness="0"
                              RowBackground="#2D2D3F" AlternatingRowBackground="#313244"
                              GridLinesVisibility="None" HeadersVisibility="Column">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#7C3AED"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="8,6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding CurrencyCode}" Width="80"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding CurrencyName}" Width="*"/>
                            <DataGridTextColumn Header="Buy (PLN)" Binding="{Binding BuyRate, StringFormat={}{0:F4}}" Width="100"/>
                            <DataGridTextColumn Header="Sell (PLN)" Binding="{Binding SellRate, StringFormat={}{0:F4}}" Width="100"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- Account Panel -->
                <StackPanel x:Name="PanelAccount" Visibility="Collapsed">
                    <TextBlock Text="My Account" FontSize="20" FontWeight="Bold"
                               Foreground="#CBA6F7" Margin="0,0,0,16"/>
                    <TextBlock x:Name="TxtBalance" FontSize="16" Margin="0,0,0,16"/>
                    <TextBlock Text="Top Up PLN Balance" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="TxtTopUp" Width="150" Margin="0,0,8,0"/>
                        <Button Content="Top Up" Click="BtnTopUp_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtTopUpMsg" Foreground="#A6E3A1" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Buy Panel -->
                <StackPanel x:Name="PanelBuy" Visibility="Collapsed">
                    <TextBlock Text="Buy Currency" FontSize="20" FontWeight="Bold"
                               Foreground="#CBA6F7" Margin="0,0,0,16"/>
                    <TextBlock Text="Currency Code (e.g. USD, EUR, GBP)"/>
                    <TextBox x:Name="TxtBuyCurrency" Width="200" HorizontalAlignment="Left" Margin="0,4,0,8"/>
                    <TextBlock Text="Amount to buy"/>
                    <TextBox x:Name="TxtBuyAmount" Width="200" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                    <Button Content="Buy" Click="BtnBuy_Click" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtBuyMsg" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Sell Panel -->
                <StackPanel x:Name="PanelSell" Visibility="Collapsed">
                    <TextBlock Text="Sell Currency" FontSize="20" FontWeight="Bold"
                               Foreground="#CBA6F7" Margin="0,0,0,16"/>
                    <TextBlock Text="Currency Code"/>
                    <TextBox x:Name="TxtSellCurrency" Width="200" HorizontalAlignment="Left" Margin="0,4,0,8"/>
                    <TextBlock Text="Amount to sell"/>
                    <TextBox x:Name="TxtSellAmount" Width="200" HorizontalAlignment="Left" Margin="0,4,0,12"/>
                    <Button Content="Sell" Click="BtnSell_Click" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtSellMsg" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- History Panel -->
                <StackPanel x:Name="PanelHistory" Visibility="Collapsed">
                    <TextBlock Text="Transaction History" FontSize="20" FontWeight="Bold"
                               Foreground="#CBA6F7" Margin="0,0,0,16"/>
                    <DataGrid x:Name="GridHistory" AutoGenerateColumns="False"
                              Background="#2D2D3F" Foreground="White" BorderThickness="0"
                              RowBackground="#2D2D3F" AlternatingRowBackground="#313244"
                              GridLinesVisibility="None">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#7C3AED"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="8,6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="130"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="70"/>
                            <DataGridTextColumn Header="Currency" Binding="{Binding CurrencyCode}" Width="80"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:F4}}" Width="100"/>
                            <DataGridTextColumn Header="Rate" Binding="{Binding Rate, StringFormat={}{0:F4}}" Width="100"/>
                            <DataGridTextColumn Header="PLN Value" Binding="{Binding PLNValue, StringFormat={}{0:F2}}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
